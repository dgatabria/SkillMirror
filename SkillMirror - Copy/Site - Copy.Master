<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="SkillMirror.SiteMaster" %>

<!DOCTYPE html>
<html lang="es">
<head runat="server">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%: Page.Title %> - SkillMirror</title>

    <%-- Bootstrap CSS --%>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <%-- Google Fonts para una tipografía moderna --%>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    <%-- Hoja de Estilos Personalizada --%>
<link href="<%= Page.ResolveUrl("~/Content/Site.css") %>" rel="stylesheet" />

    <asp:PlaceHolder runat="server">
        <%: Scripts.Render("~/bundles/modernizr") %>
    </asp:PlaceHolder>

    <webopt:bundlereference runat="server" path="~/Content/css" />
</head>
<body>
    <form id="form1" runat="server">
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top shadow-sm">
                <div class="container">
                    <a class="navbar-brand" href="<%= Page.ResolveUrl("~/") %>">
                        <%-- Usando el logo del documento --%>
                        <img src="<%= Page.ResolveUrl("~/img/skillmirror150px.png") %>" alt="SkillMirror Logo" style="height: 40px;" />
                        SkillMirror
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                       <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                            <li class="nav-item">
                                <a class="nav-link" href="<%= Page.ResolveUrl("~/Default.aspx") %>">Inicio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="<%= Page.ResolveUrl("~/QuienesSomos.aspx") %>">Quiénes Somos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="<%= Page.ResolveUrl("~/Catalogo.aspx") %>">Servicios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="<%= Page.ResolveUrl("~/Contactenos.aspx") %>">Contáctenos</a>
                            </li>
    
                            <%-- PANEL PARA USUARIOS ANÓNIMOS --%>
                            <asp:Panel ID="pnlAnonymous" runat="server">
                                <li class="nav-item ms-lg-3">
                                    <a class="btn btn-primary btn-login" href="<%= Page.ResolveUrl("~/Login.aspx") %>">Login</a>
                                </li>
                            </asp:Panel>

                            <%-- PANEL PARA USUARIOS AUTENTICADOS --%>
                            <asp:Panel ID="pnlAuthenticated" runat="server" Visible="false">
                                <li class="nav-item dropdown ms-lg-3">
                                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <asp:Label ID="lblUserName" runat="server" Text="Usuario"></asp:Label>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                                        <li><a class="dropdown-item" href="#">Mi Perfil</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <asp:LinkButton ID="btnLogout" runat="server" CssClass="dropdown-item" OnClick="BtnLogout_Click">Cerrar Sesión</asp:LinkButton>
                                        </li>
                                    </ul>
                                </li>
                            </asp:Panel>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="container">
            <asp:ContentPlaceHolder ID="MainContent" runat="server">
            </asp:ContentPlaceHolder>
        </main>

        <footer class="footer mt-auto py-3 bg-light">
            <div class="container text-center">
                <span class="text-muted">
                    © 2025 SkillMirror. Todos los derechos reservados. | 
                    <a href="<%= Page.ResolveUrl("~/PoliticaDePrivacidad.aspx") %>">Política de Privacidad</a>
                </span>
            </div>
        </footer>
        
        <%-- Bootstrap JS --%>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </form>
</body>
</html>