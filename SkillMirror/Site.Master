<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="SkillMirror.SiteMaster" %>
<%@ Import Namespace="System.Web.Optimization" %>

<!DOCTYPE html>
<html lang="es">
<head runat="server">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%: Page.Title %> - SkillMirror</title>

    <%-- Bootstrap CSS --%>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%-- Google Fonts --%>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    <%-- Hoja de Estilos Personalizada --%>
    <link href="<%= Page.ResolveUrl("~/Content/Site.css") %>" rel="stylesheet" />

    <style>
        /* --- ESTILOS MEJORADOS PARA INDICADOR DE FOCO (CONDICIONALES) --- */
        /* Solo se aplican si el body tiene la clase 'enhanced-focus-enabled' */
        body.enhanced-focus-enabled a:focus-visible,
        body.enhanced-focus-enabled button:focus-visible,
        body.enhanced-focus-enabled input:focus-visible,
        body.enhanced-focus-enabled textarea:focus-visible,
        body.enhanced-focus-enabled select:focus-visible,
        body.enhanced-focus-enabled [role="button"]:focus-visible,
        body.enhanced-focus-enabled [role="link"]:focus-visible,
        body.enhanced-focus-enabled [tabindex]:not([tabindex="-1"]):focus-visible {
            outline: 3px solid #0d6efd; /* Contorno azul más grueso */
            outline-offset: 2px;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.25);
        }
        /* Fallback para navegadores sin :focus-visible */
        @supports not selector(:focus-visible) {
            body.enhanced-focus-enabled a:focus,
            body.enhanced-focus-enabled button:focus,
            body.enhanced-focus-enabled input:focus,
            body.enhanced-focus-enabled textarea:focus,
            body.enhanced-focus-enabled select:focus,
            body.enhanced-focus-enabled [role="button"]:focus,
            body.enhanced-focus-enabled [role="link"]:focus,
            body.enhanced-focus-enabled [tabindex]:not([tabindex="-1"]):focus {
                outline: 3px solid #0d6efd;
                outline-offset: 2px;
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.25);
            }
        }
        /* ---------------------------------------------- */

        /* Estilo para el contenedor del switch de accesibilidad */
        .accessibility-toggle {
            display: flex;
            align-items: center;
            margin-left: 0.5rem; /* Ajusta espacio */
             margin-right: 0.5rem; /* Ajusta espacio */
        }
    </style>

    <asp:PlaceHolder runat="server">
        <%: Scripts.Render("~/bundles/modernizr") %>
    </asp:PlaceHolder>

    <webopt:bundlereference runat="server" path="~/Content/css" />
</head>
<body>
    <form id="form1" runat="server">
        <asp:ScriptManager runat="server"></asp:ScriptManager>
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top shadow-sm">
                <div class="container">
                    <%-- Logo y Título --%>
                    <a class="navbar-brand" href="<%= Page.ResolveUrl("~/") %>">
                        <img src="<%= Page.ResolveUrl("~/img/skillmirror150px.png") %>" alt="SkillMirror Logo" style="height: 40px;" />
                        SkillMirror
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                            <%-- Items de Navegación --%>
                            <li class="nav-item"><a id="navInicio" runat="server" class="nav-link" href="~/Default.aspx">Inicio</a></li>
                            <li class="nav-item"><a id="navQuienesSomos" runat="server" class="nav-link" href="~/QuienesSomos.aspx">Quiénes Somos</a></li>
                            <li class="nav-item"><a id="navFAQs" runat="server" class="nav-link" href="~/FAQs.aspx">FAQs</a></li>
                            <li class="nav-item"><a id="navServicios" runat="server" class="nav-link" href="~/Catalogo.aspx">Servicios</a></li>
                            <li class="nav-item"><a id="navNovedades" runat="server" class="nav-link" href="~/Novedades.aspx">Novedades</a></li>
                            <li class="nav-item"><a id="navResenas" runat="server" class="nav-link" href="~/Resenas.aspx">Reseñas</a></li>
                            <li class="nav-item"><a id="navContacto" runat="server" class="nav-link" href="~/Contactenos.aspx">Contáctenos</a></li>

                            <%-- Búsqueda --%>
                            <li class="nav-item ms-lg-3">
                                <div class="d-flex">
                                    <asp:TextBox ID="txtBusquedaGlobal" runat="server" CssClass="form-control me-2"></asp:TextBox>
                                    <asp:Button ID="btnBusquedaGlobal" runat="server" OnClick="btnBusquedaGlobal_Click" CssClass="btn btn-outline-primary" />
                                </div>
                            </li>

                            <%-- Idioma --%>
                            <li class="nav-item dropdown mx-2">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarLangDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <asp:Literal ID="litIdioma" runat="server" Text="Idioma"></asp:Literal>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarLangDropdown">
                                    <asp:Repeater ID="RepeaterIdiomas" runat="server">
                                        <ItemTemplate>
                                            <li><a class="dropdown-item" href="?langid=<%# Eval("Codigo") %>"><%# Eval("Nombre") %></a></li>
                                        </ItemTemplate>
                                    </asp:Repeater>
                                </ul>
                            </li>

                             <%-- === INTERRUPTOR DE ACCESIBILIDAD === --%>
                             <li class="nav-item accessibility-toggle">
                                 <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" id="chkEnhancedFocus">
                                    <label class="form-check-label" for="chkEnhancedFocus" id="lblEnhancedFocus" runat="server" clientidmode="Static"></label>
                                  </div>
                             </li>
                             <%-- =================================== --%>

                            <%-- Login/Usuario --%>
                            <asp:Panel ID="pnlAnonymous" runat="server">
                                <li class="nav-item ms-lg-3"><a id="navLogin" runat="server" class="btn btn-primary btn-login" href="~/Login.aspx">Login</a></li>
                            </asp:Panel>
                            <asp:Panel ID="pnlAuthenticated" runat="server" Visible="false">
                                <li class="nav-item dropdown ms-lg-3">
                                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <asp:Label ID="lblUserName" runat="server" Text="Usuario"></asp:Label>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                                        <li><a class="dropdown-item" href="/MiPerfil.aspx">Mi Perfil</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><asp:LinkButton ID="btnLogout" runat="server" CssClass="dropdown-item" OnClick="BtnLogout_Click">Cerrar Sesión</asp:LinkButton></li>
                                    </ul>
                                </li>
                            </asp:Panel>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="container" style="padding-top: 80px;"> <%-- Añadido padding-top para compensar navbar fixed --%>
            <asp:ContentPlaceHolder ID="MainContent" runat="server">
            </asp:ContentPlaceHolder>
        </main>

        <footer class="footer mt-auto py-3 bg-light">
            <div class="container text-center">
                <span class="text-muted">
                    <a id="areaderechos" runat="server"> 2025 SkillMirror. Todos los derechos reservados. |</a>
                    <a id="areapolitica" runat="server" href="~/PoliticaDePrivacidad.aspx">Política de Privacidad</a>
                </span>
            </div>
        </footer>

        <%-- Bootstrap JS --%>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

         <%-- === JAVASCRIPT PARA EL TOGGLE DE ACCESIBILIDAD === --%>
        <script type="text/javascript">
            const focusToggleSite = document.getElementById('chkEnhancedFocus'); // Usamos el mismo ID
            const storageKeySite = 'enhancedFocusEnabled'; // Usamos la misma clave

            function setFocusModeSite(enabled) {
                document.body.classList.toggle('enhanced-focus-enabled', enabled);
            }

            focusToggleSite.addEventListener('change', function() {
                const isEnabled = this.checked;
                setFocusModeSite(isEnabled);
                localStorage.setItem(storageKeySite, isEnabled);
            });

            document.addEventListener('DOMContentLoaded', function() {
                const savedPreference = localStorage.getItem(storageKeySite);
                if (savedPreference !== null && savedPreference === 'true') {
                    focusToggleSite.checked = true;
                    setFocusModeSite(true);
                } else {
                    focusToggleSite.checked = false;
                    setFocusModeSite(false);
                }
            });
        </script>
         <%-- ============================================== --%>

    </form>
</body>
</html>
