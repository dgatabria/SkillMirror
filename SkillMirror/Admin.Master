<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Admin.master.cs" Inherits="SkillMirror.AdminMaster" %>
<%@ Import Namespace="System.Web.Optimization" %>

<!DOCTYPE html>
<html lang="es">
<head runat="server">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%: Page.Title %> - Consola SkillMirror</title>

    <%-- Links CSS/Fonts --%>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    <style>
        /* Estilos generales */
        body {
            font-family: 'Roboto', sans-serif;
            background-color: #f8f9fa;
        }
        .sidebar {
            background-color: #343a40;
            padding: 1rem;
            min-height: 100vh;
        }
        .sidebar .nav-link {
            color: #adb5bd;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
            transition: all 0.2s ease-in-out;
        }
        .sidebar .nav-link.active, .sidebar .nav-link:hover {
            color: #ffffff;
            background-color: #495057;
        }
        .top-navbar {
            background-color: #ffffff;
            border-bottom: 1px solid #dee2e6;
        }

        /* --- ESTILOS MEJORADOS PARA INDICADOR DE FOCO (CONDICIONALES) --- */
        body.enhanced-focus-enabled a:focus-visible,
        body.enhanced-focus-enabled button:focus-visible,
        body.enhanced-focus-enabled input:focus-visible,
        body.enhanced-focus-enabled textarea:focus-visible,
        body.enhanced-focus-enabled select:focus-visible,
        body.enhanced-focus-enabled [role="button"]:focus-visible,
        body.enhanced-focus-enabled [role="link"]:focus-visible,
        body.enhanced-focus-enabled [tabindex]:not([tabindex="-1"]):focus-visible {
            outline: 3px solid #0d6efd; /* Contorno azul más grueso */
            outline-offset: 2px;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.25);
        }
        @supports not selector(:focus-visible) {
            body.enhanced-focus-enabled a:focus,
            body.enhanced-focus-enabled button:focus,
            body.enhanced-focus-enabled input:focus,
            body.enhanced-focus-enabled textarea:focus,
            body.enhanced-focus-enabled select:focus,
            body.enhanced-focus-enabled [role="button"]:focus,
            body.enhanced-focus-enabled [role="link"]:focus,
            body.enhanced-focus-enabled [tabindex]:not([tabindex="-1"]):focus {
                outline: 3px solid #0d6efd;
                outline-offset: 2px;
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.25);
            }
        }
        /* ---------------------------------------------- */

        /* Estilo para el contenedor del switch de accesibilidad */
        .accessibility-toggle {
            display: flex;
            align-items: center;
            margin-left: 1rem;
        }
    </style>
</head>
<body>
    <form id="form1" runat="server">

        <asp:ScriptManager runat="server">
            <Scripts>
                <asp:ScriptReference Name="WebForms.js" Assembly="System.Web" Path="~/Scripts/WebForms/WebForms.js" />
                <asp:ScriptReference Name="WebUIValidation.js" Assembly="System.Web" Path="~/Scripts/WebForms/WebUIValidation.js" />
                <asp:ScriptReference Name="MenuStandards.js" Assembly="System.Web" Path="~/Scripts/WebForms/MenuStandards.js" />
                <asp:ScriptReference Name="GridView.js" Assembly="System.Web" Path="~/Scripts/WebForms/GridView.js" />
                <asp:ScriptReference Name="DetailsView.js" Assembly="System.Web" Path="~/Scripts/WebForms/DetailsView.js" />
                <asp:ScriptReference Name="TreeView.js" Assembly="System.Web" Path="~/Scripts/WebForms/TreeView.js" />
                <asp:ScriptReference Name="WebParts.js" Assembly="System.Web" Path="~/Scripts/WebForms/WebParts.js" />
                <asp:ScriptReference Name="Focus.js" Assembly="System.Web" Path="~/Scripts/WebForms/Focus.js" />
                <asp:ScriptReference Name="WebFormsBundle" />
            </Scripts>
        </asp:ScriptManager>

        <nav class="navbar top-navbar fixed-top shadow-sm">
            <div class="container-fluid">
                <%-- Logo y Título --%>
                <a id="headerTitle" runat="server" class="navbar-brand" href="~/Consola.aspx">
                    <img src="~/img/skillmirror150px.png" alt="SkillMirror Logo" style="height: 35px;" />
                    Consola de Administración
                </a>

                <%-- Búsqueda --%>
                <div class="d-flex me-auto ms-4">
                    <asp:TextBox ID="txtBusquedaGlobal" runat="server" CssClass="form-control me-2"></asp:TextBox>
                    <asp:Button ID="btnBusquedaGlobal" runat="server" OnClick="btnBusquedaGlobal_Click" CssClass="btn btn-outline-secondary" />
                </div>

                <ul class="navbar-nav ms-auto d-flex flex-row align-items-center">
                    <%-- Idioma --%>
                    <li class="nav-item dropdown mx-3">
                       <a class="nav-link dropdown-toggle" href="#" id="navbarLangDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <asp:Literal ID="litIdioma" runat="server" Text="Idioma"></asp:Literal>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarLangDropdown">
                            <asp:Repeater ID="RepeaterIdiomas" runat="server">
                                <ItemTemplate>
                                    <li>
                                        <a class="dropdown-item" href="?langid=<%# Eval("Codigo") %>">
                                            <%# Eval("Nombre") %>
                                        </a>
                                    </li>
                                </ItemTemplate>
                            </asp:Repeater>
                        </ul>
                    </li>

                     <%-- === INTERRUPTOR DE ACCESIBILIDAD === --%>
                     <li class="nav-item accessibility-toggle">
                         <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="chkEnhancedFocus">
                            <%-- Usamos ClientIDMode="Static" para que el ID sea predecible en JS --%>
                            <label class="form-check-label" for="chkEnhancedFocus" id="lblEnhancedFocus" runat="server" clientidmode="Static"></label>
                          </div>
                     </li>
                     <%-- =================================== --%>


                     <%-- Menú Usuario --%>
                     <li class="nav-item dropdown ms-3">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <asp:Label ID="lblUserName" runat="server" Text="Usuario"></asp:Label>
                        </a>
                         <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                            <li><a id="linkMiPerfil" runat="server" class="dropdown-item" href="~/MiPerfil.aspx">Mi Perfil</a></li>
                             <li><a id="linkMisMensajes" runat="server" class="dropdown-item" href="~/MisMensajes.aspx">Mis Mensajes</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <asp:LinkButton ID="btnLogout" runat="server" CssClass="dropdown-item" OnClick="BtnLogout_Click">Cerrar Sesión</asp:LinkButton>
                            </li>
                        </ul>
                     </li>
                </ul>
            </div>
        </nav>

        <div class="container-fluid">
            <div class="row">
                <%-- Sidebar --%>
                <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse" style="padding-top: 60px;">
                     <div class="position-sticky">
                        <asp:Repeater ID="rptMenu" runat="server">
                             <HeaderTemplate><ul class="nav flex-column nav-pills"></HeaderTemplate>
                             <ItemTemplate><li class="nav-item"><a class='<%# Eval("CssClass") %>' href='<%# Page.ResolveUrl(Eval("Url").ToString()) %>'><%# Eval("Texto") %></a></li></ItemTemplate>
                            <FooterTemplate></ul></FooterTemplate>
                        </asp:Repeater>
                    </div>
                </nav>

                <%-- Contenedor Principal --%>
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4" style="padding-top: 80px;">
                     <asp:ContentPlaceHolder ID="MainContent" runat="server">
                    </asp:ContentPlaceHolder>
                </main>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

         <%-- === JAVASCRIPT PARA EL TOGGLE DE ACCESIBILIDAD === --%>
        <script type="text/javascript">
            const focusToggle = document.getElementById('chkEnhancedFocus');
            const storageKey = 'enhancedFocusEnabled';

            function setFocusMode(enabled) {
                document.body.classList.toggle('enhanced-focus-enabled', enabled);
            }

            focusToggle.addEventListener('change', function() {
                const isEnabled = this.checked;
                setFocusMode(isEnabled);
                localStorage.setItem(storageKey, isEnabled);
            });

            document.addEventListener('DOMContentLoaded', function() {
                const savedPreference = localStorage.getItem(storageKey);
                if (savedPreference !== null && savedPreference === 'true') {
                    focusToggle.checked = true;
                    setFocusMode(true);
                } else {
                    focusToggle.checked = false;
                    setFocusMode(false);
                }
            });
        </script>
         <%-- ============================================== --%>

    </form>
</body>
</html>

